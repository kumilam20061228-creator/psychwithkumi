    linear-gradient(135deg, var(--muted) 50%, transparent 50%);
  background-position:
    calc(100% - 18px) calc(50% - 3px),
    calc(100% - 12px) calc(50% - 3px);
  background-size: 6px 6px, 6px 6px;
  background-repeat:no-repeat;
  padding-right:34px;
}

/* Post view */
.post-view{ margin-top:18px; }

.post-content{
  max-width:75ch;
}

/* Blog post images: not huge */
.post-content img{
  width:100%;
  max-width:460px;   /* smaller */
  height:auto;
  display:block;
  margin:28px auto;
  border-radius:20px;
  box-shadow:0 8px 18px rgba(232,139,179,.15);
}

/* Footer */
.site-footer{
  border-top:1px solid var(--line);
  padding:30px 0;
  margin-top:60px;
  background:#ffffffcc;
  font-size:14px;
}

.footer-inner{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:14px;
  flex-wrap:wrap;
}

/* Mobile */
@media (max-width:900px){
  .hero-grid{ grid-template-columns:1fr; }
  .grid{ grid-template-columns:1fr; }

  .nav-toggle{ display:inline-block; }

  .nav-menu{
    display:none;
    position:absolute;
    right:20px;
    top:64px;
    background:#fff;
    border:1px solid var(--line);
    border-radius:16px;
    padding:10px;
    flex-direction:column;
    align-items:stretch;
    min-width: 220px;
    box-shadow:var(--shadow);
  }

  .nav-menu.open{ display:flex; }
}
/* Blog post content images */
.post-content img{
  max-width: 100%;
  height: auto;
  display: block;
  margin: 14px auto;
  border-radius: 16px;
}

/* Card images on the homepage */
.card-image{
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 16px;
  display: block;
  margin-bottom: 14px;
}
